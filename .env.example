# Bot配置
BOT_TOKEN=你的Bot Token

# Telegram API配置 (从 https://my.telegram.org 获取)
TELEGRAM_API_ID=你的API ID
TELEGRAM_API_HASH=你的API Hash

# 授权用户ID (你的Telegram用户ID，只有这个用户可以使用Bot)
AUTHORIZED_USER_ID=你的用户ID

# 数据库文件路径
DATABASE_PATH=./telegram_monitor.db

# 会话文件存储路径
SESSION_PATH=./sessions

# 代理配置（可选）
# PROXY_TYPE 支持: none / socks5 / http / mtproxy
# Socks5/HTTP 使用 PROXY_HOST + PROXY_PORT，可选 PROXY_USERNAME + PROXY_PASSWORD
# MTProxy 使用 PROXY_HOST + PROXY_PORT + PROXY_SECRET
# PROXY_TYPE=none
# PROXY_HOST=127.0.0.1
# PROXY_PORT=1080
# PROXY_USERNAME=
# PROXY_PASSWORD=
# PROXY_SECRET=

# 日志级别
LOG_LEVEL=INFO
